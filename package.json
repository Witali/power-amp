{
  "name": "power-amp",
  "version": "0.1.0",
  "private": true,
  "description": "Local workspace for transistor amplifier research, schematics, simulation, OCR, and generated results.",
  "scripts": {
    "build": "python scripts/project_tasks.py all",
    "check": "python scripts/project_tasks.py check",
    "go:build": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/build_go_tools.ps1",
    "go:test": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/build_go_tools.ps1 -SkipBuild",
    "go:smoke": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/build_go_tools.ps1 -Smoke -Crops",
    "layout:calibrate": "python scripts/project_tasks.py layout-calibrate",
    "layout:frequency": "python scripts/analyze_page_frequency.py",
    "layout:report": "python scripts/generate_opencv_layout_report.py",
    "lint:svg": "python scripts/lint_svg.py",
    "project:index": "python scripts/generate_project_index.py",
    "radio:contents-html": "python scripts/project_tasks.py radio-contents-html",
    "radio:contents-refine": "python scripts/project_tasks.py radio-contents-refine",
    "render:svg": "python scripts/project_tasks.py render",
    "spellcheck": "python scripts/project_tasks.py spellcheck",
    "symbols": "python scripts/project_tasks.py symbols",
    "test": "python -m unittest discover -s tests"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2"
  }
}
